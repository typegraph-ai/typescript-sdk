{
  "name": "@d8um-ai/graph",
  "version": "0.1.3",
  "description": "Knowledge graph, cognitive memory, and neural retrieval for d8um - entities, edges, PPR, extraction, consolidation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
