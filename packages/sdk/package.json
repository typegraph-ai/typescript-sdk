{
  "name": "@typegraph-ai/sdk",
  "version": "0.2.8",
  "description": "TypeScript SDK for retrieval, knowledge graph, and cognitive memory for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.0"
  },
  "peerDependencies": {
    "ai": "^6.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@ai-sdk/gateway": "^3.0.0",
    "ai": "^6.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "zod": "^4.3.6"
  }
}
